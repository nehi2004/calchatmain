<configuration>
	<system.webServer>
		<handlers>
			<add name="aspNetCore" path="*" verb="*"
				 modules="AspNetCoreModuleV2" resourceType="Unspecified" />
		</handlers>
		<aspNetCore processPath=".\CalChatAPI.exe"
            stdoutLogEnabled="true"
            stdoutLogFile=".\logs\stdout"
            hostingModel="inprocess" />
	</system.webServer>
</configuration>